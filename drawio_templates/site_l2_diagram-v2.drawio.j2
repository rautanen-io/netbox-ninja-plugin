{#- 
    This template produces L2 Network Diagram for a NetBox Site    
#}
{#- 
    General variables  
#}
{%- set base_url =  "http://127.0.0.1:8000" -%}
{#- 
    Styles 
#}
{%- set shape_router_style_base = "shape=image;editableCssRules=.*;labelBackgroundColor=none;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;html=1;spacing=8;" %}
{%- set shape_fw_style_base = "shape=image;editableCssRules=.*;labelBackgroundColor=none;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;html=1;spacing=8;" %}
{%- set shape_sw_style_base = "shape=image;editableCssRules=.*;labelBackgroundColor=none;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;html=1;spacing=8;" %}
{%- set shape_eh_style_base = "shape=image;editableCssRules=.*;labelBackgroundColor=none;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;html=1;spacing=8;" %}
{%- set styles = {
        "shape_fw_style":  shape_fw_style_base ~ ";labelPosition=center;align=middle;verticalLabelPosition=top;verticalAlign=middle;",
        "shape_sw_style":  shape_sw_style_base ~ ";labelPosition=center;align=middle;verticalLabelPosition=top;verticalAlign=middle;",
        "shape_router_style":  shape_router_style_base ~ ";labelPosition=center;align=middle;verticalLabelPosition=top;verticalAlign=middle;",
        "shape_eh_style":  shape_eh_style_base ~ ";labelPosition=center;align=middle;verticalLabelPosition=top;verticalAlign=middle;"
    }
%}
{%- set int_text_style = "whiteSpace=wrap;html=1;rounded=1;arcSize=50;fontSize=10;fillColor=none;fontColor=light-dark( #006600, #03F2D4);strokeColor=light-dark( #006600, #03F2D4);" %}
{%- set int_text_style_red = "whiteSpace=wrap;html=1;rounded=1;arcSize=50;fontSize=10;fillColor=none;fontColor=light-dark( #f64206ff, #f76464ff);strokeColor=light-dark( #f64206ff, #f76464ff);" %}
{%- set int_text_style_blue = "whiteSpace=wrap;html=1;rounded=1;arcSize=50;fontSize=10;fillColor=none;fontColor=light-dark( #203fefff, #5762fcff);strokeColor=light-dark( #203fefff, #5762fcff);" %}
{%- set dev_text_style = "&quot;color: light-dark(rgb(0, 120, 94), rgb(3, 242, 212));&quot;" %}
{%- set connector_style = "edgeStyle=elbowEdgeStyle;html=1;jumpStyle=gap;endArrow=none;endFill=0;strokeColor=light-dark( #006600, #03F2D4);arcSize=10;" %}
{%- set connector_style_red = "edgeStyle=elbowEdgeStyle;html=1;jumpStyle=gap;endArrow=none;endFill=0;strokeColor=light-dark( #f64206ff, #f76464ff);arcSize=10;" %}
{%- set connector_style_blue = "edgeStyle=elbowEdgeStyle;html=1;jumpStyle=gap;endArrow=none;endFill=0;strokeColor=light-dark( #203fefff, #5762fcff);arcSize=10;" %}
{#- 
    Location & Dimension related variables 
#}
{%- set col_x_init =  300 %}
{%- set dev_y_init =  200 %}
{%- set dev_y_spacing =  100 %}
{%- set col_x_spacing =  460 %}
{%- set int_x_spacing =  20 %}
{%- set dev_width =  30 %}
{%- set dev_height =  dev_width %}
{%- set int_height =  17 %}
{%- set int_y_spacing =  5 %}
{%- set iface_y_unit = int_height +  int_y_spacing %}
{%- set vertical_line_x_spacing = 13 %}
{%- set char_width = 8 %}
{%- set int_char_width = 6 %}
{%- set int_label_margin = 6 %}
{#- 
    Misc.
#}
{%- set ns = namespace(column_data={},column_meta_data={},roles_for_columns=[],filtered_column_devices={},filtered_names_for_columns=[]) %}
{%- set role_symbols = {
        "Firewall": "shape_fw_style",
        "Distribution Switch": "shape_router_style",
        "Access Switch": "shape_router_style",
        "PC": "shape_eh_style"
    }
%}
{%- set column_1_roles = [
        "Firewall"
    ]
%}
{%- set column_2_roles = [
        "Distribution Switch"
    ]
%}
{%- set column_3_roles = [
        "Access Switch"
    ]
%}
{%- set column_4_roles = [
        "PC"
    ]
%}
{%- set init_roles_for_columns = [
        column_1_roles,
        column_2_roles,
        column_3_roles,
        column_4_roles
    ]
%}
{#-
    Reusable macros
#}
{#- Macro for device #}
{%- macro mac_device(device, shape_style, x, y) %}
            <mxCell id="device-{{ device.name }}" value="&lt;a href=&quot;{{ base_url }}{{ device.get_absolute_url() }}&quot;&gt;&lt;font style={{ dev_text_style }}&gt;{{ device.name }}&lt;/a&gt;" style="{{ shape_style }}" vertex="1" parent="1">
                <mxGeometry x="{{ x }}" y="{{ y }}" width="{{ dev_width }}" height="{{ dev_height }}" as="geometry" />
            </mxCell>
{%- endmacro %}
{#- Interface name formatting rules shared across the template #}
{%- set interface_name_replacements = [
    ('GigabitEthernet', 'Gi'),
    ('ethernet', 'Eth')
    ] 
-%}
{%- macro format_int_name(name) -%}
    {%- set ns = namespace(out=name) -%}
    {%- for from_name, to_name in interface_name_replacements -%}
        {%- set ns.out = ns.out.replace(from_name, to_name) -%}
    {%- endfor -%}
    {{- ns.out -}}
{%- endmacro -%}
{#- Macro for interface #}
{%- macro mac_int(device_name, int, text_style, x, y, label,width=57, height=17) %}
            <object label="&lt;a href=&quot;{{ base_url }}{{ int.get_absolute_url() }}&quot;&gt;{{ label | default(format_int_name(int.name)) }}&lt;/a&gt;" id="{{ device_name }}-{{ int.name }}">
                <mxCell style="{{ text_style }}" vertex="1" parent="1">
                    <mxGeometry x="{{ x }}" y="{{ y }}" width="{{ width }}" height="{{ height }}" as="geometry"/>
                </mxCell>
            </object>
{%- endmacro %}
{#- Macro for cable #}
{%- macro mac_cable(source, target, x, y, style) %}
            <object label="" id="{{ source }}-{{ target }}">
                <mxCell style="{{ style | default(connector_style) }}" edge="1" parent="1" source="{{ source }}" target="{{ target }}">
                    <mxGeometry relative="1" as="geometry">
                        {%- if x and y %}
                        <Array as="points">
                            <mxPoint x="{{ x }}" y="{{ y }}"/>
                        </Array>
                        {%- endif %}
                    </mxGeometry>
                </mxCell>
            </object>
{%- endmacro %}
{#- 
    # First section - Data fetching
    
    In this section, data is fetched and save to better
    format in order to draw diagram easily
#}
{#- 
    Drop columns without devices
#}
{%- set ns_filter = namespace(device_names=[]) %}
{%- set selected_filter_devices = [] %}
{%- if filter_devices is defined and filter_devices is not none %}
{%-   set selected_filter_devices = filter_devices %}
{%- endif %}

{%- if selected_filter_devices is not none %}
{%-   for device in selected_filter_devices %}
{%-     if
          device
          and device.status == 'active'
          and device.site_id == target_object.pk
      -%}
{%-       set _ = ns_filter.device_names.append(device.name) %}
{%-     endif %}
{%-   endfor %}
{%- endif %}
{%- set apply_connectivity_filter = ns_filter.device_names | length > 0 %}

{#-
    Build role-preserving, connectivity-filtered device names per column.
    Last column is limited by filter_devices (when present), and previous
    columns include only devices connected to devices in the next column.
#}
{%- set ns_tmp = namespace(next_col_device_names=[]) %}
{%- for col_index in range(init_roles_for_columns | length - 1, -1, -1) %}
{%-   set role_col = init_roles_for_columns[col_index] %}
{%-   set role_devices = devices.filter(
          role__name__in = role_col,
          status = 'active',
          site_id = target_object.pk
      ) | sort(attribute='name')
  %}
{%-   set col_device_names = [] %}
{%-   if not apply_connectivity_filter %}
{%-     if col_index < (init_roles_for_columns | length - 1) %}
{%-       for device in role_devices %}
{%-         if device.name not in col_device_names %}
{%-           set _ = col_device_names.append(device.name) %}
{%-         endif %}
{%-       endfor %}
{%-     endif %}
{%-   elif col_index == (init_roles_for_columns | length - 1) %}
{%-     for device in role_devices %}
{%-       if device.name in ns_filter.device_names %}
{%-         set _ = col_device_names.append(device.name) %}
{%-       endif %}
{%-     endfor %}
{%-   else %}
{%-     for device in role_devices %}
{%-       if ns_tmp.next_col_device_names | length %}
{%-         for iface in interfaces.filter(
                    device=device,
                    cable__isnull=False
                )
        %}
{%-           if
                iface.link_peers[0]
                and iface.link_peers[0].device
                and iface.link_peers[0].device.site_id == target_object.pk
                and iface.link_peers[0].device.status == 'active'
                and iface.link_peers[0].device.name in ns_tmp.next_col_device_names
                and device.name not in col_device_names
            -%}
{%-             set _ = col_device_names.append(device.name) %}
{%-           endif %}
{%-         endfor %}
{%-       endif %}
{%-     endfor %}
{%-   endif %}
{%-   set _ = ns.filtered_column_devices.update({'col-' + col_index|string: col_device_names}) %}
{%-   set ns_tmp.next_col_device_names = col_device_names %}
{%- endfor %}

{%- for col in init_roles_for_columns %}
{%-   set col_index = loop.index0 %}
{%-   set filtered_names = ns.filtered_column_devices['col-' + col_index|string] %}
{%-   if filtered_names | length %}
{%-     set _ = ns.roles_for_columns.append(col) %}
{%-     set _ = ns.filtered_names_for_columns.append(filtered_names) %}
{%-   endif %}
{#- 
    Loop columns (group of roles)
#}
{%- endfor %}
{%- for col in ns.roles_for_columns %}
{%-   set _ = ns.column_data.update(
        {
            'col-' + loop.index0|string: {}  
        }
    )
%}
{%-   set ns2 = namespace(
                    grand_loop_index = loop.index0,
                    dev_count_downlinks = 0,
                    max_left_remote_label_len = 3,
                    max_left_local_label_len = 3,
                    max_right_remote_label_len = 3,
                    max_right_local_label_len = 3
                ) 
%}
{#- 
      Loop devices inside column
#}
{%-   for device in devices.filter(
        role__name__in = col,
        status = 'active',
        site_id = target_object.pk,
        name__in = ns.filtered_names_for_columns[ns2.grand_loop_index]
    ) | sort(attribute='role.name')
%}
{%-     set _ = ns.column_data['col-' + ns2.grand_loop_index|string].update(
            {
                device.name: {
                    "device": device,
                    "interfaces": {},
                    "location": {},
                    "has_other_column_links": false
                }
            }
        )
%}
{%-     set ns3 = namespace(downlinks = false, uplinks = false) %}
{#- 
        Loop device interfaces
#}
{%-     for iface in interfaces.filter(
                device=device,
                cable__isnull=False
            )
%}
{%-       if
            ns2.grand_loop_index > 0
            and iface.link_peers[0]
            and iface.link_peers[0].device
            and iface.link_peers[0].device.site_id == target_object.pk
            and iface.link_peers[0].device.status == 'active'
            and iface.link_peers[0].device.role.name in ns.roles_for_columns[ns2.grand_loop_index - 1]
            and iface.link_peers[0].device.name in ns.filtered_names_for_columns[ns2.grand_loop_index - 1]
-%}
{%-         set _ = ns.column_data['col-' + ns2.grand_loop_index|string][device.name]['interfaces'].update(
                {
                    iface.name: {
                        "local_int": iface,
                        "remote_int": iface.link_peers[0]
                    }
                }
            )
%}
{%-         set ns3.uplinks = true %}
{%-         set local_if_name = format_int_name(iface.name) %}
{%-         set remote_if_name = format_int_name(iface.link_peers[0].name) %}
{%-         if local_if_name | length > ns2.max_left_local_label_len -%}
{%-           set ns2.max_left_local_label_len = local_if_name | length %}
{%-         endif %}
{%-         if remote_if_name | length > ns2.max_left_remote_label_len -%}
{%-           set ns2.max_left_remote_label_len = remote_if_name | length %}
{%-         endif %}
{#-       Following section is to figure out if this device has downlinks #}
{%-       elif
            iface.link_peers[0]
            and iface.link_peers[0].device
            and iface.link_peers[0].device.site_id == target_object.pk
            and iface.link_peers[0].device.status == 'active'
            and iface.link_peers[0].device.role.name in ns.roles_for_columns[ns2.grand_loop_index + 1]
            and iface.link_peers[0].device.name in ns.filtered_names_for_columns[ns2.grand_loop_index + 1]
-%}
{%-         set ns3.downlinks = true %}
{%-         set local_if_name = format_int_name(iface.name) %}
{%-         set remote_if_name = format_int_name(iface.link_peers[0].name) %}
{%-         if local_if_name | length > ns2.max_right_local_label_len -%}
{%-           set ns2.max_right_local_label_len = local_if_name | length %}
{%-         endif %}
{%-         if remote_if_name | length > ns2.max_right_remote_label_len -%}
{%-           set ns2.max_right_remote_label_len = remote_if_name | length %}
{%-         endif %}
{%-       endif %}
{%-    endfor %}
{#-      Following section count how many devices in column has downlinks #}
{%-      if ns3.uplinks or ns3.downlinks -%}
{%-        set _ = ns.column_data['col-' + ns2.grand_loop_index|string][device.name].update(
                {
                    "has_other_column_links": true
                }
            )
%}
{%-      endif %}
{#-      Following section count how many devices in column has downlinks #}
{%-      if ns3.downlinks -%}
{%-        set ns2.dev_count_downlinks = ns2.dev_count_downlinks + 1 %}
{%-      endif %}
{%-   endfor %}
{#-   Reorder devices: first with links to next column, then without; both alphabetically by hostname #}
{%-   set sorted_column_devices = {} %}
{%-   for dname, ddata in ns.column_data['col-' + ns2.grand_loop_index|string] | dictsort %}
{%-     if ddata.has_other_column_links %}
{%-       set _ = sorted_column_devices.update({dname: ddata}) %}
{%-     endif %}
{%-   endfor %}
{%-   for dname, ddata in ns.column_data['col-' + ns2.grand_loop_index|string] | dictsort %}
{%-     if not ddata.has_other_column_links %}
{%-       set _ = sorted_column_devices.update({dname: ddata}) %}
{%-     endif %}
{%-   endfor %}
{%-   set _ = ns.column_data.update(
        {
            'col-' + ns2.grand_loop_index|string: sorted_column_devices
        }
    )
%}
{#-   Following section saves max hostname length of the coliumn and count how many devices in column has downlinks #}
{%-   set max_hostname_len = devices.filter(
                            role__name__in=col,
                            status='active',
                            site_id=target_object.pk,
                            name__in = ns.filtered_names_for_columns[ns2.grand_loop_index]
                        ) | map(attribute='name') | map('length') | max %}
{%-   set left_remote_int_width = ns2.max_left_remote_label_len * int_char_width + int_label_margin %}
{%-   set left_local_int_width = ns2.max_left_local_label_len * int_char_width + int_label_margin %}
{%-   set right_remote_int_width = ns2.max_right_remote_label_len * int_char_width + int_label_margin %}
{%-   set right_local_int_width = ns2.max_right_local_label_len * int_char_width + int_label_margin %}
{%-   if ns.roles_for_columns[loop.index0 + 1] %}
{%-     set next_col_max_hostname_len = devices.filter(
                                role__name__in = ns.roles_for_columns[loop.index0 + 1],
                                status = 'active',
                                site_id = target_object.pk,
                                name__in = ns.filtered_names_for_columns[loop.index0 + 1]
                            )
                            | map(attribute='name')
                            | map('length')
                            | max
%}
{%-     set x_right_0 = dev_width / 2
                    + (max_hostname_len * char_width) / 2
                    + 10
                    + ns2.dev_count_downlinks * vertical_line_x_spacing
                    + 10
                    + right_remote_int_width
                    + 20
                    + right_local_int_width
                    + 25
                    + (next_col_max_hostname_len * char_width) / 2
                    - dev_width / 2
%}
{%-     if ns2.grand_loop_index == 0 %}
{%-       set x_right = col_x_init + x_right_0 %}
{%-     else %}
{%-       set x_right = ns.column_meta_data['col-' + (ns2.grand_loop_index - 1)|string]['x_right'] + x_right_0 %}
{%-     endif %}
{%-   else %}
{%-     set x_right = 0 %}
{%-   endif %}
{%-   set _ = ns.column_meta_data.update(
        {
            'col-' + loop.index0|string: {
                "max_hostname_len": max_hostname_len,
                "left_remote_int_width": left_remote_int_width,
                "left_local_int_width": left_local_int_width,
                "dev_count_downlinks": ns2.dev_count_downlinks,
                "x_right": x_right
            }
        }
    )
%}
{%- endfor %}
{#- 
    
    XML begins

#}
<!--
    This is L2 Network Diagram for a NetBox Site: {{ target_object.name }}
-->
<mxfile>
  <diagram name="Page-1" id="diagram_{{ target_object.id }}">
    <mxGraphModel dx="867" dy="541" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="0" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="2000" math="0" shadow="0">
        <root>
            <mxCell id="0" />
            <mxCell id="1" parent="0" />
            <!--
                Columns
            -->
            {%- for col,data in ns.column_data.items() %}
            {%-   set ns2 = namespace(grand_loop_index = loop.index0, y_offset = 0, device_index = 0, next_col_remote_ifaces = []) %}
            {#-
                    Fetch next column remote interfaces into a list
            #}
            {%-   if
                ns.column_data['col-' + (loop.index0 + 1) | string] is defined
                and ns.column_data['col-' + (loop.index0 + 1) | string]
            %}
            {%-     for ncdev, dev_data in ns.column_data['col-' + (loop.index0 + 1) | string].items() %}
            {%-       for iface_name, iface_data in dev_data.interfaces.items() %}
            {%-         set _ = ns2.next_col_remote_ifaces.append(iface_data.remote_int) %}
            {%-       endfor %}
            {%-     endfor %}
            {%-   endif %}
            <!--
                Columns | Devices
            -->
            {%-   for dname,device in data.items() %}
            {%-     set iface_count = device.interfaces | length %}
            {%-     set int_height_total = iface_count * iface_y_unit %}
            {%-     if ns2.grand_loop_index == 0 %}
            {%-       set dev_x = col_x_init %}
            {%-     else %}
            {%-       set dev_x = ns.column_meta_data['col-' + (ns2.grand_loop_index - 1)|string]['x_right'] %}
            {%-     endif %}
            {%-     set dev_y = dev_y_init + 
                                (dev_y_spacing / 2) * (ns2.grand_loop_index % 2) + 
                                ns2.y_offset + int_height_total / 2 
            %}
            {#-
                    Check if this device has connections to next column devices
            #}
            {%-      set device_ifaces_in_other = ns2.next_col_remote_ifaces | selectattr("device.id", "equalto", device.device.id) | list | length %}
            {#-     
                    Save location for later use
            #}
            {%-   if ns2.next_col_remote_ifaces | selectattr("device.id", "equalto", device.device.id) | list | length %}
            {%-     set _ = ns.column_data['col-' + ns2.grand_loop_index|string][dname]['location'].update(
                {
                    "x": dev_x,
                    "y": dev_y,
                    "index": ns2.device_index
                }
            )
            %}
            {%-     set ns2.device_index = ns2.device_index + 1  %}
            {%-   else %}
            {%-     set _ = ns.column_data['col-' + ns2.grand_loop_index|string][dname]['location'].update(
                {
                    "x": dev_x,
                    "y": dev_y
                }
            )
            %}
            {%-   endif %}
            {%-     if dev_y_spacing < int_height_total %}
            {%-       set ns2.y_offset = ns2.y_offset + int_height_total %}
            {%-     else %}
            {%-       set ns2.y_offset = ns2.y_offset + dev_y_spacing %}
            {%-     endif %}
            {{- mac_device(
                    device = device.device,
                    shape_style = styles[role_symbols[device.device.role.name]] | default(styles.shape_eh_style),
                    x = dev_x,
                    y = dev_y
                )            
            }}
            {%-     for iname,int in device.interfaces.items() %}
            {%-       if
                        ns2.grand_loop_index > 0
                        and int.remote_int.device is defined
            -%}
            {%-       set int_y = ns.column_data['col-' + ns2.grand_loop_index|string][dname]['location'].y + (loop.index0 - (loop.length - 1)/2) * iface_y_unit + dev_height/2 - int_height/2 %}
            {%-       set remote_int_x = ns.column_data['col-' + (ns2.grand_loop_index - 1)|string][int.remote_int.device.name]['location'].x 
                                        + dev_width / 2
                                        + (ns.column_meta_data['col-' + (ns2.grand_loop_index - 1)|string]['max_hostname_len'] / 2) * char_width
                                        + 10
                                        + ns.column_meta_data['col-' + (ns2.grand_loop_index - 1)|string]['dev_count_downlinks'] * vertical_line_x_spacing
            %}
            {%-       set local_int_x = remote_int_x + int_x_spacing + ns.column_meta_data['col-' + (ns2.grand_loop_index)|string]['left_remote_int_width'] %}
            {#- Local interface #}
            {{- mac_int(
                    device_name = dname,
                    int = int.local_int,
                    text_style = int_text_style,
                    x = local_int_x,
                    y = int_y,
                    width = ns.column_meta_data['col-' + (ns2.grand_loop_index)|string]['left_local_int_width'],
                    height = int_height
                )            
            }}
            {#- Remote interface #}
            {{- mac_int(
                    device_name = int.remote_int.device.name,
                    int = int.remote_int,
                    text_style = int_text_style,
                    x = remote_int_x,
                    y = int_y,
                    width = ns.column_meta_data['col-' + (ns2.grand_loop_index)|string]['left_remote_int_width'],
                    height = int_height
                )            
            }}
            {#- Cable from local device to local interface #}
            {{- mac_cable(
                    source = "device-" + dname,
                    target = dname + "-" + int.local_int.name,
                    x = local_int_x + ns.column_meta_data['col-' + (ns2.grand_loop_index)|string]['left_local_int_width'] + 25,
                    y = ns.column_data['col-' + ns2.grand_loop_index|string][dname]['location'].y + dev_height / 2,
                    style = connector_style
                )
            }}
            {#- Cable from local interface to remote interface #}
            {{- mac_cable(
                    source = dname + "-" + int.local_int.name,
                    target = int.remote_int.device.name + "-" + int.remote_int.name,
                    style = connector_style
                )
            }}
            {#- Cable from remote interface to remote device #}
            {{- mac_cable(
                    source = int.remote_int.device.name + "-" + int.remote_int.name,
                    target = "device-" + int.remote_int.device.name,
                    x = ns.column_data['col-' + (ns2.grand_loop_index - 1)|string][int.remote_int.device.name]['location'].x 
                        + dev_width / 2
                        + (ns.column_meta_data['col-' + (ns2.grand_loop_index - 1)|string]['max_hostname_len'] / 2) * char_width
                        + 10
                        + vertical_line_x_spacing * ns.column_data['col-' + (ns2.grand_loop_index - 1)|string][int.remote_int.device.name]['location'].index,
                    y = int_y + int_height / 2,
                    style = connector_style + 'entryX=1;entryY=0.5'
                )
            }}
            {%-       endif %}
            {%-     endfor %}
            {%-   endfor %}
            {%- endfor %}
        </root>
    </mxGraphModel>
  </diagram>
</mxfile>